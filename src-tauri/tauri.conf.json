{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OrbisDeck",
  "version": "0.7.0",
  "identifier": "com.akurach.orbisdeck",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OrbisDeck",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Project command center for Claude Code",
    "longDescription": "OrbisDeck — a single shell for managing multiple Claude Code projects: terminals, files, git, agents, docs and config in one window."
  }
}
