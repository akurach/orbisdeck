{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OrbisDeck",
  "version": "0.1.0",
  "identifier": "com.akurach.orbisdeck",
  "build": {
    "frontendDist": "../out/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "OrbisDeck",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": ["icons/icon.icns", "icons/icon.png"]
  }
}
